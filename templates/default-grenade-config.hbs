<form class="default-grenade-config-form">
    <nav class="tabs" data-group="primary">
        <a class="item active" data-tab="colors"><i class="fas fa-palette"></i> Colors</a>
        <a class="item" data-tab="explosion"><i class="fas fa-bomb"></i> Explosion</a>
        <a class="item" data-tab="emp"><i class="fas fa-bolt"></i> EMP</a>
        <a class="item" data-tab="flashbang"><i class="fas fa-sun"></i> Flashbang</a>
        <a class="item" data-tab="smoke"><i class="fas fa-cloud"></i> Smoke</a>
    </nav>

    <section class="tab-content">
        <div class="tab active" data-group="primary" data-tab="colors">
            <div class="grenade-color-grid">
                {{#each colorList}}
                <div class="grenade-color-row">
                    <label>{{this.label}}</label>
                    <input type="color" name="{{this.key}}" value="{{this.value}}">
                </div>
                {{/each}}
            </div>
        </div>

        <div class="tab" data-group="primary" data-tab="explosion">
            <div class="effect-section">
                <p class="effect-hint">Used for: Basic, Expansive, Rubber, Smart, Armor Piercing, Incendiary, Acid grenades</p>
                <div class="form-group">
                    <label>Animation File</label>
                    <div class="form-fields">
                        <input type="text" name="explosionAnimation" value="{{explosionAnimation}}">
                        <button type="button" class="file-picker" data-type="imagevideo" data-target="explosionAnimation" title="Browse Files"><i class="fas fa-file-import fa-fw"></i></button>
                    </div>
                </div>
                <div class="form-group">
                    <label>Sound File</label>
                    <div class="form-fields">
                        <input type="text" name="explosionSound" value="{{explosionSound}}">
                        <button type="button" class="file-picker" data-type="audio" data-target="explosionSound" title="Browse Files"><i class="fas fa-file-import fa-fw"></i></button>
                    </div>
                </div>
                <div class="form-group">
                    <label>Volume (0–1)</label>
                    <input type="number" name="explosionVolume" value="{{explosionVolume}}" min="0" max="1" step="0.1">
                </div>
                <div class="form-group">
                    <label>Scale</label>
                    <input type="number" name="explosionScale" value="{{explosionScale}}" min="0.1" max="3" step="0.1">
                </div>
            </div>
        </div>

        <div class="tab" data-group="primary" data-tab="emp">
            <div class="effect-section">
                <div class="effect-subsection-label">Explosion</div>
                <div class="form-group">
                    <label>Animation File</label>
                    <div class="form-fields">
                        <input type="text" name="empCenterAnimation" value="{{empCenterAnimation}}">
                        <button type="button" class="file-picker" data-type="imagevideo" data-target="empCenterAnimation" title="Browse Files"><i class="fas fa-file-import fa-fw"></i></button>
                    </div>
                </div>
                <div class="form-group">
                    <label>Scale</label>
                    <input type="number" name="empCenterScale" value="{{empCenterScale}}" min="0.1" max="3" step="0.1">
                </div>
                <div class="effect-subsection-label">Aftermath (On-Tokens)</div>
                <div class="form-group">
                    <label>Animation File</label>
                    <div class="form-fields">
                        <input type="text" name="empAnimation" value="{{empAnimation}}">
                        <button type="button" class="file-picker" data-type="imagevideo" data-target="empAnimation" title="Browse Files"><i class="fas fa-file-import fa-fw"></i></button>
                    </div>
                </div>
                <div class="form-group">
                    <label>Scale</label>
                    <input type="number" name="empScale" value="{{empScale}}" min="0.1" max="3" step="0.1">
                </div>
                <div class="effect-subsection-label">Audio</div>
                <div class="form-group">
                    <label>Sound File</label>
                    <div class="form-fields">
                        <input type="text" name="empSound" value="{{empSound}}">
                        <button type="button" class="file-picker" data-type="audio" data-target="empSound" title="Browse Files"><i class="fas fa-file-import fa-fw"></i></button>
                    </div>
                </div>
                <div class="form-group">
                    <label>Volume (0–1)</label>
                    <input type="number" name="empVolume" value="{{empVolume}}" min="0" max="1" step="0.1">
                </div>
            </div>
        </div>

        <div class="tab" data-group="primary" data-tab="flashbang">
            <div class="effect-section">
                <div class="effect-subsection-label">Explosion</div>
                <div class="form-group">
                    <label>Animation File</label>
                    <div class="form-fields">
                        <input type="text" name="flashbangCenterAnimation" value="{{flashbangCenterAnimation}}">
                        <button type="button" class="file-picker" data-type="imagevideo" data-target="flashbangCenterAnimation" title="Browse Files"><i class="fas fa-file-import fa-fw"></i></button>
                    </div>
                </div>
                <div class="form-group">
                    <label>Scale</label>
                    <input type="number" name="flashbangCenterScale" value="{{flashbangCenterScale}}" min="0.1" max="3" step="0.1">
                </div>
                <div class="effect-subsection-label">Aftermath (On-Tokens)</div>
                <div class="form-group">
                    <label>Animation File</label>
                    <div class="form-fields">
                        <input type="text" name="flashbangAnimation" value="{{flashbangAnimation}}">
                        <button type="button" class="file-picker" data-type="imagevideo" data-target="flashbangAnimation" title="Browse Files"><i class="fas fa-file-import fa-fw"></i></button>
                    </div>
                </div>
                <div class="form-group">
                    <label>Scale</label>
                    <input type="number" name="flashbangScale" value="{{flashbangScale}}" min="0.1" max="3" step="0.1">
                </div>
                <div class="effect-subsection-label">Audio</div>
                <div class="form-group">
                    <label>Sound File</label>
                    <div class="form-fields">
                        <input type="text" name="flashbangSound" value="{{flashbangSound}}">
                        <button type="button" class="file-picker" data-type="audio" data-target="flashbangSound" title="Browse Files"><i class="fas fa-file-import fa-fw"></i></button>
                    </div>
                </div>
                <div class="form-group">
                    <label>Volume (0–1)</label>
                    <input type="number" name="flashbangVolume" value="{{flashbangVolume}}" min="0" max="1" step="0.1">
                </div>
            </div>
        </div>

        <div class="tab" data-group="primary" data-tab="smoke">
            <div class="effect-section">
                <div class="form-group">
                    <label>Animation File</label>
                    <div class="form-fields">
                        <input type="text" name="smokeAnimation" value="{{smokeAnimation}}">
                        <button type="button" class="file-picker" data-type="imagevideo" data-target="smokeAnimation" title="Browse Files"><i class="fas fa-file-import fa-fw"></i></button>
                    </div>
                </div>
                <div class="form-group">
                    <label>Scale</label>
                    <input type="number" name="smokeScale" value="{{smokeScale}}" min="0.1" max="3" step="0.1">
                </div>
            </div>
        </div>
    </section>

    <footer class="sheet-footer">
        <button type="submit"><i class="fas fa-save"></i> Save Changes</button>
    </footer>
</form>