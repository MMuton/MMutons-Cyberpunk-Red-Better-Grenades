<form class="grenade-color-config-form">
    <div class="form-header">
        <h2>Grenade Template Colors</h2>
        <p class="hint">Configure the template colors for each grenade type. Colors affect the blast template appearance when grenades are thrown.</p>
    </div>
    
    <div class="color-grid">
        {{#each colorSettings}}
        <div class="color-setting-row">
            <div class="color-setting-info">
                <label for="{{key}}" class="color-label">{{name}}</label>
                <p class="color-hint">{{hint}}</p>
            </div>
            <div class="color-input-container">
                <input type="color" 
                       id="{{key}}" 
                       name="{{key}}" 
                       value="{{value}}" 
                       class="color-picker"
                       title="{{name}}">
                <input type="text" 
                       name="{{key}}-text" 
                       value="{{value}}" 
                       class="color-text"
                       pattern="^#[0-9A-Fa-f]{6}$"
                       placeholder="#FFFFFF">
            </div>
        </div>
        {{/each}}
    </div>
    
    <div class="form-footer">
        <button type="submit" class="save-colors">
            <i class="fas fa-save"></i> Save Colors
        </button>
        <button type="button" class="reset-colors">
            <i class="fas fa-undo"></i> Reset to Defaults
        </button>
    </div>
</form>

<style>
.grenade-color-config-form {
    padding: 15px;
}

.form-header {
    margin-bottom: 20px;
    border-bottom: 1px solid #ccc;
    padding-bottom: 10px;
}

.form-header h2 {
    margin: 0 0 5px 0;
    color: #333;
}

.form-header .hint {
    margin: 0;
    color: #666;
    font-style: italic;
}

.color-grid {
    display: flex;
    flex-direction: column;
    gap: 15px;
    margin-bottom: 20px;
}

.color-setting-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 10px;
    border: 1px solid #ddd;
    border-radius: 4px;
    background: #f9f9f9;
}

.color-setting-info {
    flex: 1;
    margin-right: 15px;
}

.color-label {
    font-weight: bold;
    color: #333;
    display: block;
    margin-bottom: 3px;
}

.color-hint {
    margin: 0;
    font-size: 11px;
    color: #666;
}

.color-input-container {
    display: flex;
    align-items: center;
    gap: 8px;
}

.color-picker {
    width: 40px;
    height: 30px;
    border: 1px solid #ccc;
    border-radius: 3px;
    cursor: pointer;
    padding: 0;
}

.color-text {
    width: 80px;
    padding: 5px;
    border: 1px solid #ccc;
    border-radius: 3px;
    font-family: monospace;
    font-size: 12px;
}

.form-footer {
    display: flex;
    justify-content: space-between;
    padding-top: 15px;
    border-top: 1px solid #ccc;
}

.save-colors, .reset-colors {
    padding: 8px 16px;
    border: none;
    border-radius: 4px;
    cursor: pointer;
    font-weight: bold;
    display: flex;
    align-items: center;
    gap: 5px;
}

.save-colors {
    background: #4CAF50;
    color: white;
}

.save-colors:hover {
    background: #45a049;
}

.reset-colors {
    background: #f44336;
    color: white;
}

.reset-colors:hover {
    background: #d32f2f;
}
</style>

<script>
// Sync color picker and text input
document.addEventListener('change', function(e) {
    if (e.target.classList.contains('color-picker')) {
        const textInput = document.querySelector(`input[name="${e.target.name}-text"]`);
        if (textInput) textInput.value = e.target.value;
    }
    
    if (e.target.classList.contains('color-text')) {
        const colorPicker = document.querySelector(`input[name="${e.target.name.replace('-text', '')}"]`);
        if (colorPicker && /^#[0-9A-Fa-f]{6}$/.test(e.target.value)) {
            colorPicker.value = e.target.value;
        }
    }
});

// Reset to defaults
document.querySelector('.reset-colors')?.addEventListener('click', function() {
    if (confirm('Reset all colors to defaults? This cannot be undone.')) {
        const defaults = {
            colorBasic: "#FFFF00",
            colorAcid: "#80FF00", 
            colorArmorPiercing: "#FF3366",
            colorBiotoxin: "#00FF00",
            colorEmp: "#0080FF",
            colorExpansive: "#FF6600",
            colorFlashbang: "#FFFFFF",
            colorIncendiary: "#FF4500",
            colorPoison: "#90FF90",
            colorRubber: "#404040",
            colorSleep: "#9932CC",
            colorSmart: "#00FFFF",
            colorSmoke: "#888888",
            colorTeargas: "#FFFF00",
            colorSpecial: "#FF69B4"
        };
        
        Object.entries(defaults).forEach(([key, value]) => {
            const colorPicker = document.querySelector(`input[name="${key}"]`);
            const textInput = document.querySelector(`input[name="${key}-text"]`);
            if (colorPicker) colorPicker.value = value;
            if (textInput) textInput.value = value;
        });
    }
});
</script>